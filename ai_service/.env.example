# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5000

# Security
SECRET_KEY=your-super-secret-flask-key-change-this-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yourdomain.com,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/ai_service.log

# SSL/TLS
SSL_CERT_PATH=/path/to/ssl/certificate.crt
SSL_KEY_PATH=/path/to/ssl/private.key
