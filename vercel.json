{
  "version": 2,
  {
  "outputDirectory": "dist"
}
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ai_service/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "ai_service/app.py"
    },
    {
      "src": "/api/route",
      "dest": "ai_service/app.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/dist/$1"
    }
    {
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
